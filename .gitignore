# ============================================================
# RuralSliceAI - .gitignore
# ============================================================

##############################################################
# Python
##############################################################

__pycache__/
*.py[cod]
*$py.class

##############################################################
# Virtual Environments
##############################################################

.venv/
venv/
env/
ENV/

##############################################################
# Python Packaging
##############################################################

build/
dist/
*.egg-info/
.eggs/

##############################################################
# Testing
##############################################################

.pytest_cache/
.coverage
htmlcov/

##############################################################
# Jupyter
##############################################################

.ipynb_checkpoints/

##############################################################
# IDEs
##############################################################

.vscode/
.idea/

##############################################################
# Linux
##############################################################

*~
*.swp
*.swo

##############################################################
# macOS
##############################################################

.DS_Store

##############################################################
# Windows
##############################################################

Thumbs.db
Desktop.ini

##############################################################
# Logs
##############################################################

*.log

##############################################################
# Runtime Files
##############################################################

*.pid
*.sock

##############################################################
# Generated Experiment Files
##############################################################

results/*.tmp
results/*.cache

##############################################################
# Generated Figures (optional)
##############################################################

# Uncomment if figures are generated every run
# results/*.png
# results/*.pdf

##############################################################
# Generated CSVs (optional)
##############################################################

# Keep experimental CSVs tracked.
# If they become very large, uncomment below.
# results/*.csv

##############################################################
# Mininet
##############################################################

mn.log

##############################################################
# Open vSwitch
##############################################################

ovsdb.log

##############################################################
# Traffic Captures
##############################################################

*.pcap
*.pcapng

##############################################################
# Temporary Files
##############################################################

tmp/
temp/
*.tmp

##############################################################
# Secrets
##############################################################

.env
.env.*
*.key
*.pem

##############################################################
# Compiled Libraries
##############################################################

*.so
*.dll
*.dylib

##############################################################
# Archives
##############################################################

*.zip
*.tar
*.tar.gz
*.rar

##############################################################
# Backup Files
##############################################################

*.bak
*.old

##############################################################
# Local Configuration
##############################################################

config/local.py
local_settings.py